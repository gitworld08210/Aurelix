rules_version = '2';

// Aurelix Firestore security rules.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }
    function userDoc(uid) { return get(/databases/$(database)/documents/users/$(uid)).data; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).isAdmin == true;
    }

    // ---- Users ----
    match /users/{uid} {
      allow read: if true; // public profiles
      allow create: if isSelf(uid);
      // Owner can edit their profile. Counters may be incremented by others (follow).
      allow update: if isSelf(uid) || isAdmin()
        || (signedIn() && onlyCountersChanged());
      allow delete: if isSelf(uid) || isAdmin();

      function onlyCountersChanged() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followersCount', 'followingCount', 'postsCount', 'reelsCount']);
      }

      // username reservation
      match /private/{doc} {
        allow read, write: if isSelf(uid);
      }
    }

    // Username uniqueness index: /usernames/{usernameLower} -> { uid }
    match /usernames/{name} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ---- Follows: /follows/{followerId_followingId} ----
    match /follows/{id} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
    }

    // ---- Posts ----
    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount','commentsCount'])
      );
      allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isAdmin());

      match /likes/{uid} {
        allow read: if true;
        allow write: if isSelf(uid);
      }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // ---- Reels ----
    match /reels/{reelId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount','commentsCount','viewsCount','savesCount'])
      );
      allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isAdmin());

      match /likes/{uid} { allow read: if true; allow write: if isSelf(uid); }
      match /saves/{uid} { allow read: if isSelf(uid); allow write: if isSelf(uid); }
      match /comments/{commentId} {
        allow read: if true;
        allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
        allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // ---- Saved reels per user (for quick lookup) ----
    match /users/{uid}/saved/{reelId} {
      allow read, write: if isSelf(uid);
    }

    // ---- Notifications: /notifications/{uid}/items/{id} ----
    match /notifications/{uid}/items/{id} {
      allow read: if isSelf(uid);
      allow update, delete: if isSelf(uid);
      // anyone signed in can create a notification for another user (follow/like/comment)
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
    }

    // ---- Conversations & messages ----
    match /conversations/{cid} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && request.auth.uid in resource.data.members;

      match /messages/{mid} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members;
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members;
        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members;
      }
      match /typing/{uid} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.members;
        allow write: if isSelf(uid);
      }
    }

    // ---- WebRTC call signaling ----
    match /calls/{callId} {
      allow read, update, delete: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.callerId == request.auth.uid;

      // ICE candidates from each side
      match /callerCandidates/{c} { allow read, write: if signedIn(); }
      match /calleeCandidates/{c} { allow read, write: if signedIn(); }
    }

    // ---- Verification requests ----
    match /verificationRequests/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create, update: if isSelf(uid);
      allow delete: if isAdmin() || isSelf(uid);
    }
  }
}
